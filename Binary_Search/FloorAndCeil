#include <bits/stdc++.h>
using namespace std;

pair<int, int> getFloorAndCeil(vector<int> &arr, int n, int x) {
	int low = 0, high = n-1;
    int ans_floor = -1, ans_ceil = -1;

    while(low <= high){
        int mid = (low + high)/2;
        if (arr[mid]==x) return {x,x};
        else if (arr[mid] > x){
            ans_ceil = arr[mid];
            high = mid-1;
        }
		
        else{
			ans_floor = arr[mid];
			low = mid+1;
		} 
    }
    return {ans_floor,ans_ceil};
}

